// Mock API Playground - Database Schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// BETTER-AUTH MODELS
// ============================================

model user {
  id            String    @id
  email         String    @unique
  name          String?
  image         String?
  emailVerified Boolean   @default(false)

  // Relations
  sessions      session[]
  accounts      account[]
  projects      Project[]
  apiKeys       ApiKey[]
  templates     SchemaTemplate[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  idToken               String?

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============================================
// MOCK API CORE MODELS
// ============================================

model Project {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?

  // Owner
  user        user       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String

  // Relations
  endpoints   Endpoint[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
}

model Endpoint {
  id              String   @id @default(cuid())
  name            String?
  path            String
  method          HttpMethod @default(GET)
  description     String?

  // Schema & Response
  schema          Json
  responseCode    Int      @default(200)
  responseHeaders Json?

  // Behavior
  delay           Int      @default(0)        // Response delay in ms
  isArray         Boolean  @default(false)    // Return array of items
  arrayCount      Int      @default(10)       // Number of items if array
  pagination      Boolean  @default(false)    // Enable pagination
  stateful        Boolean  @default(false)    // Enable CRUD state
  stateData       Json?                       // Persisted state data

  // Access Control
  authRequired    Boolean  @default(false)
  rateLimit       Int?                        // Requests per minute
  corsOrigins     String[] @default([])       // Allowed origins (empty = all)

  // Status
  enabled         Boolean  @default(true)

  // Relations
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId       String
  requests        Request[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([projectId, path, method])
  @@index([projectId])
  @@index([enabled])
}

model Request {
  id         String   @id @default(cuid())

  // Request Details
  method     String
  path       String
  query      Json?
  headers    Json?
  body       Json?

  // Response Info
  statusCode Int
  duration   Int      // Response time in ms

  // Client Info
  ip         String?
  userAgent  String?

  // Relations
  endpoint   Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  endpointId String

  createdAt  DateTime @default(now())

  @@index([endpointId])
  @@index([createdAt])
}

// ============================================
// API KEYS
// ============================================

model ApiKey {
  id        String    @id @default(cuid())
  key       String    @unique
  name      String

  // Owner
  user      user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  // Usage tracking
  lastUsed  DateTime?
  usageCount Int      @default(0)

  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@index([userId])
  @@index([key])
}

// ============================================
// SCHEMA TEMPLATES
// ============================================

model SchemaTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  schema      Json

  // Owner
  user        user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ============================================
// ENUMS
// ============================================

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
  OPTIONS
  HEAD
}
